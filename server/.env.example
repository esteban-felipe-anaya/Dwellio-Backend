# Copy to .env and adjust. All values have safe local defaults.

# App
PROJECT_NAME=Dwellio API
ENV=dev
DEBUG=true

# Security — CHANGE in production.
SECRET_KEY=dev-insecure-secret-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
# Leave unset to use the zero-install SQLite fallback (./dev.sqlite3).
# PostgreSQL (documented target):
# DATABASE_URL=postgresql+asyncpg://dwellio:dwellio@localhost:5432/dwellio
# DATABASE_URL=

# Media / uploads
MEDIA_ROOT=media
MEDIA_URL=/media
MAX_UPLOAD_MB=10

# Seed
SEED_DATA_PATH=app/seed/seed_data.json

# CORS (comma-separated). Admin runs on :3001; Flutter web dev on :3000.
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:3000
